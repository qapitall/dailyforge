# DailyForge secrets — never commit this file. It is already listed in .gitignore.
# Copy to .env and fill in the values for your provider + Discord webhooks.

# --- Provider API token ---------------------------------------------------
# Only the token for your configured `provider` (config.json) is required.
# The instance hostname is NOT set here — it lives in config.json's `host` field.

# provider: github  -> no token here; authenticate the gh CLI with `gh auth login`.

# provider: gitlab  -> create a Personal Access Token:
#   https://<your-gitlab-host>/-/user_settings/personal_access_tokens
#   Required scopes: read_api, read_repository
# GITLAB_TOKEN=glpat-...

# provider: gitea   -> create an access token:
#   https://<your-gitea-host>/user/settings/applications
#   Required scope: read-only repository access
# GITEA_TOKEN=...

# --- Discord webhook URLs -------------------------------------------------
# One variable per recipient; the names must match `webhook_env` in config.json.
DISCORD_WEBHOOK_LEAD=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_AHMET=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_TEAM=https://discord.com/api/webhooks/...
